
# =============================================================================
# Musicalo — docker-compose.yml.example
#
# Copia este archivo a docker-compose.yml y ajusta los valores.
# El comportamiento depende de START_MODE (ver sección "Modos de arranque").
# =============================================================================

# =============================================================================
# MODOS DE ARRANQUE (START_MODE)
# =============================================================================
#
#  telegram  (por defecto)
#    Solo bot de Telegram. Comportamiento original.
#    No expone ningún puerto.
#
#  api
#    Solo API REST en el puerto indicado (API_PORT, por defecto 8000).
#    Útil para conectar una UI externa (Chainlit, app móvil, etc.).
#    No requiere TELEGRAM_BOT_TOKEN.
#    Swagger disponible en http://localhost:8000/docs
#
#  both
#    Telegram + API REST simultáneamente.
#    Requiere TELEGRAM_BOT_TOKEN y expone el puerto de la API.
#
# =============================================================================
# CONFIGURACIÓN RECOMENDADA SEGÚN USO
# =============================================================================
#
#  Solo Telegram (original):
#    START_MODE=telegram
#    # Comentar la sección "ports" del servicio musicalo
#
#  Telegram + acceso desde frontend web:
#    START_MODE=both
#    MUSICALO_API_KEY=genera-una-clave-segura
#
#  Solo API (para conectar Chainlit u otra UI):
#    START_MODE=api
#    MUSICALO_API_KEY=genera-una-clave-segura
#    # Descomentar el servicio "frontend" más abajo
#
# =============================================================================

services:

  # ---------------------------------------------------------------------------
  # Servicio principal: Musicalo
  # ---------------------------------------------------------------------------
  musicalo:
    image: alvaromolrui/musicalo:latest
    container_name: musicalo
    restart: unless-stopped
    environment:
      # --- Navidrome ---
      - NAVIDROME_URL=${NAVIDROME_URL}
      - NAVIDROME_USERNAME=${NAVIDROME_USERNAME}
      - NAVIDROME_PASSWORD=${NAVIDROME_PASSWORD}

      # --- ListenBrainz ---
      - LISTENBRAINZ_USERNAME=${LISTENBRAINZ_USERNAME}
      - LISTENBRAINZ_TOKEN=${LISTENBRAINZ_TOKEN}

      # --- MusicBrainz ---
      - ENABLE_MUSICBRAINZ=${ENABLE_MUSICBRAINZ:-true}
      - APP_NAME=${APP_NAME:-MusicaloBot}
      - CONTACT_EMAIL=${CONTACT_EMAIL}
      - MUSICBRAINZ_BATCH_SIZE=${MUSICBRAINZ_BATCH_SIZE:-15}
      - MUSICBRAINZ_MAX_TOTAL=${MUSICBRAINZ_MAX_TOTAL:-100}

      # --- Gemini AI ---
      - GEMINI_API_KEY=${GEMINI_API_KEY}

      # --- Telegram (solo necesario si START_MODE=telegram o both) ---
      - TELEGRAM_BOT_TOKEN=${TELEGRAM_BOT_TOKEN}
      - TELEGRAM_ALLOWED_USER_IDS=${TELEGRAM_ALLOWED_USER_IDS}
      - TELEGRAM_ADMIN_USER_IDS=${TELEGRAM_ADMIN_USER_IDS}

      # --- Modo de arranque ---
      - START_MODE=${START_MODE:-telegram}

      # --- API REST (solo si START_MODE=api o both) ---
      - MUSICALO_API_KEY=${MUSICALO_API_KEY:-}   # vacío = sin autenticación
      - HOST=0.0.0.0
      - PORT=8000

    # Puerto de la API REST. Comentar esta sección si START_MODE=telegram.
    ports:
      - "${API_PORT:-8000}:8000"

    volumes:
      - logs:/app/logs
      - config:/app/config

    networks:
      - musicalo-network

  # ---------------------------------------------------------------------------
  # Servicio frontend — Chainlit (chat web)
  # ---------------------------------------------------------------------------
  # Requisitos previos:
  #   - START_MODE=api o both en el servicio musicalo
  #   - MUSICALO_API_KEY configurada con el mismo valor en ambos servicios
  #
  # Acceso: http://localhost:8080  (o el FRONTEND_PORT que configures)
  #
  frontend:
    # Para producción (imagen publicada en Docker Hub):
    image: alvaromolrui/musicalo-frontend:main
    # Para desarrollo local (build desde el código fuente):
    # build: ./frontend
    container_name: musicalo-frontend
    restart: unless-stopped
    ports:
      - "${FRONTEND_PORT:-8080}:8080"
    environment:
      - BACKEND_URL=http://musicalo:8000
      - MUSICALO_API_KEY=${MUSICALO_API_KEY:-}
    depends_on:
      - musicalo
    networks:
      - musicalo-network

networks:
  musicalo-network:
    driver: bridge

volumes:
  logs:
    driver: local
  config:
    driver: local

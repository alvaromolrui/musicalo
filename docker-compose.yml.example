services:
  musicalo:
    image: alvaromolrui/musicalo:latest
    container_name: musicalo
    restart: unless-stopped
    environment:
      # Navidrome Configuration
      - NAVIDROME_URL=${NAVIDROME_URL}
      - NAVIDROME_USERNAME=${NAVIDROME_USERNAME}
      - NAVIDROME_PASSWORD=${NAVIDROME_PASSWORD}

      # ListenBrainz Configuration
      - LISTENBRAINZ_USERNAME=${LISTENBRAINZ_USERNAME}
      - LISTENBRAINZ_TOKEN=${LISTENBRAINZ_TOKEN}

      # MusicBrainz Configuration
      - ENABLE_MUSICBRAINZ=${ENABLE_MUSICBRAINZ:-true}
      - APP_NAME=${APP_NAME:-MusicaloBot}
      - CONTACT_EMAIL=${CONTACT_EMAIL}
      - MUSICBRAINZ_BATCH_SIZE=${MUSICBRAINZ_BATCH_SIZE:-15}
      - MUSICBRAINZ_MAX_TOTAL=${MUSICBRAINZ_MAX_TOTAL:-100}

      # Gemini Configuration
      - GEMINI_API_KEY=${GEMINI_API_KEY}

      # Telegram Bot Configuration
      - TELEGRAM_BOT_TOKEN=${TELEGRAM_BOT_TOKEN}
      - TELEGRAM_ALLOWED_USER_IDS=${TELEGRAM_ALLOWED_USER_IDS}

      # Modo de arranque
      # telegram  → solo bot de Telegram (por defecto, comportamiento original)
      # api       → solo API REST en el puerto indicado
      # both      → Telegram + API REST simultáneamente
      - START_MODE=${START_MODE:-telegram}

      # API REST — clave de acceso opcional (deja vacío para acceso abierto en red privada)
      - MUSICALO_API_KEY=${MUSICALO_API_KEY:-}
      - HOST=0.0.0.0
      - PORT=8000

    # Puerto de la API REST (solo se usa si START_MODE=api o both)
    ports:
      - "${API_PORT:-8000}:8000"

    volumes:
      - logs:/app/logs
      - config:/app/config

    networks:
      - musicalo-network

networks:
  musicalo-network:
    driver: bridge

volumes:
  logs:
    driver: local
  config:
    driver: local
